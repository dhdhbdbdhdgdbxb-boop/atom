generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique @db.VarChar(50)
  email         String         @unique @db.VarChar(100)
  password      String?        @db.VarChar(255)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  lastLogin     DateTime?      @map("last_login")
  emailVerified DateTime?      @map("email_verified")
  image         String?        @db.VarChar(255)
  balanceUsd    Decimal        @default(0.00) @map("balance_usd") @db.Decimal(10, 2)
  balanceRub    Decimal        @default(0.00) @map("balance_ru") @db.Decimal(10, 2)
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
  purchases     UserPurchase[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Admin {
  id          Int       @id @default(autoincrement())
  login       String    @unique @db.VarChar(50)
  password    String    @db.VarChar(255)
  permissions String?   @db.Text
  owner       Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLogin   DateTime? @map("last_login")
  frozen      Boolean   @default(false)
  twoFaSecret String?   @map("two_fa_secret") @db.VarChar(255)
  twoFaEnabled Boolean  @default(false) @map("two_fa_enabled")

  @@map("admins")
}

model Game {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?    @db.Text
  icon        String?    @db.VarChar(255)
  background  String?    @db.VarChar(255)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  isNew       Boolean    @default(false)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  image       String?    @db.VarChar(255)
  categories  Category[]
  products    Product[]

  @@map("games")
}

model Category {
  id           Int                   @id @default(autoincrement())
  slug         String                @db.VarChar(100)
  description  String?               @db.Text
  icon         String?               @db.VarChar(255)
  background   String?               @db.VarChar(255)
  image        String?               @db.VarChar(255)
  isActive     Boolean               @default(true)
  sortOrder    Int                   @default(0)
  isNew        Boolean               @default(false)
  gameId       Int                   @map("game_id")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  game         Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  translations CategoryTranslation[]
  products     Product[]

  @@unique([slug, gameId])
  @@index([gameId], map: "categories_game_id_fkey")
  @@map("categories")
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("category_id")
  language   String   @db.VarChar(10)
  name       String   @db.VarChar(100)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@index([language])
  @@map("category_translations")
}

model Product {
  id                     Int                            @id @default(autoincrement())
  slug                   String                         @unique @db.VarChar(200)
  status                 String                         @default("undetected") @db.VarChar(50)
  isActive               Boolean                        @default(true)
  gameId                 Int                            @map("game_id")
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")
  screenshots            String?                        @db.Text
  categoryId             Int?                           @map("category_id")
  regions                String                         @db.Text
  subscriptionTypes      String                         @db.Text
  orders                 Order[]
  features               ProductFeature[]
  media                  ProductMedia[]
  systemRequirementItems ProductSystemRequirementItem[]
  systemRequirements     ProductSystemRequirements[]
  translations           ProductTranslation[]
  variants               ProductVariant[]
  category               Category?                      @relation(fields: [categoryId], references: [id])
  game                   Game                           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  purchases              UserPurchase[]

  @@index([gameId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductTranslation {
  id              Int     @id @default(autoincrement())
  productId       Int     @map("product_id")
  language        String  @db.VarChar(10)
  name            String  @db.VarChar(200)
  description     String? @db.Text
  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.Text
  metaKeywords    String? @map("meta_keywords") @db.Text
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@index([language])
  @@map("product_translations")
}

model ProductFeature {
  id        Int              @id @default(autoincrement())
  productId Int              @map("product_id")
  language  String           @db.VarChar(10)
  title     String           @db.VarChar(200)
  parentId  Int?             @map("parent_id")
  sortOrder Int              @default(0)
  parent    ProductFeature?  @relation("FeatureHierarchy", fields: [parentId], references: [id])
  children  ProductFeature[] @relation("FeatureHierarchy")
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language, title, parentId])
  @@index([productId])
  @@index([language])
  @@index([parentId])
  @@map("product_features")
}

model ProductSystemRequirements {
  id          Int                            @id @default(autoincrement())
  productId   Int                            @map("product_id")
  language    String                         @db.VarChar(10)
  gameClient  String?                        @db.Text
  supportedOS String?                        @db.Text
  antiCheats  String?                        @db.Text
  processors  String?                        @db.Text
  spoofer     Boolean                        @default(false)
  gameMode    Boolean                        @default(false)
  items       ProductSystemRequirementItem[]
  product     Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@index([productId])
  @@map("product_system_requirements")
}

model ProductSystemRequirementItem {
  id            Int                       @id @default(autoincrement())
  requirementId Int                       @map("requirement_id")
  title         String                    @db.VarChar(100)
  description   String?                   @db.Text
  icon          String?                   @db.VarChar(50)
  sortOrder     Int                       @default(0)
  language      String                    @default("ru") @db.VarChar(10)
  productId     Int?                      @map("product_id")
  product       Product?                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  requirement   ProductSystemRequirements @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([productId])
  @@map("product_system_requirement_items")
}

model ProductVariant {
  id           Int            @id @default(autoincrement())
  productId    Int            @map("product_id")
  type         String         @db.VarChar(20)
  region       String         @db.VarChar(20)
  days         Int
  keys         String         @db.Text
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  priceRub     Decimal        @map("price_rub") @db.Decimal(10, 2)
  priceUsd     Decimal        @map("price_usd") @db.Decimal(10, 2)
  stock        Int            @default(0)
  instructions String?        @db.Text
  daysLabelEn  String?        @db.VarChar(50)
  daysLabelRu  String?        @db.VarChar(50)
  orders       Order[]
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  reservedKeys ReservedKey[]
  purchases    UserPurchase[]

  @@unique([productId, type, region, days], name: "unique_product_variant")
  @@index([productId])
  @@index([type])
  @@index([region])
  @@index([isActive])
  @@map("product_variants")
}

model ProductMedia {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  type        String   @db.VarChar(20)
  url         String   @db.VarChar(500)
  thumbnail   String?  @db.VarChar(500)
  fileName    String?  @map("file_name") @db.VarChar(255)
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type") @db.VarChar(100)
  width       Int?
  height      Int?
  duration    Int?
  isMainImage Boolean  @default(false) @map("is_main_image")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@index([isMainImage])
  @@map("product_media")
}

model News {
  id            Int               @id @default(autoincrement())
  slug          String            @unique @db.VarChar(255)
  featuredImage String?           @db.VarChar(255)
  status        String            @default("draft") @db.VarChar(50)
  isPublished   Boolean           @default(false)
  isFeatured    Boolean           @default(false)
  sortOrder     Int               @default(0)
  viewCount     Int               @default(0)
  uniqueViews   Int               @default(0)
  author        String            @db.VarChar(100)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  publishedAt   DateTime?         @map("published_at")
  archiveAt     DateTime?         @map("archive_at")
  languageReady Boolean           @default(false)
  archiveReady  Boolean           @default(false)
  translations  NewsTranslation[]
  visits        Visit[]

  @@index([status])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([sortOrder])
  @@index([languageReady])
  @@index([archiveReady])
  @@map("news")
}

model NewsTranslation {
  id              Int     @id @default(autoincrement())
  newsId          Int     @map("news_id")
  language        String  @db.VarChar(10)
  title           String  @db.VarChar(255)
  excerpt         String? @db.Text
  content         String  @db.Text
  metaTitle       String? @db.VarChar(255)
  metaDescription String? @db.Text
  keywords        String? @db.Text
  news            News    @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([newsId, language])
  @@index([language])
  @@map("news_translations")
}

model Visit {
  id         Int      @id @default(autoincrement())
  newsId     Int      @map("news_id")
  viewerId   String   @db.VarChar(32)
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  date       DateTime @default(now())
  uniqueView Boolean  @default(true)
  news       News     @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([newsId, viewerId, date])
  @@index([newsId])
  @@index([viewerId])
  @@index([date])
  @@map("visits")
}

model PageVisit {
  id        Int      @id @default(autoincrement())
  viewerId  String   @unique @db.VarChar(36)
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  date      DateTime @default(now())
  isUnique  Boolean  @default(true)

  @@index([date])
  @@map("page_visits")
}

model Order {
  id             String          @id @default(uuid())
  userId         Int?            @map("user_id")
  productId      Int?            @map("product_id")
  variantId      Int?            @map("variant_id")
  type           String          @default("order") @db.VarChar(20) // "order" or "deposit"
  status         String          @default("pending") @db.VarChar(50)
  email          String          @db.VarChar(255)
  referralCode   String?         @db.VarChar(50)
  paymentMethod  String          @db.VarChar(50)
  paymentStatus  String          @default("pending") @db.VarChar(50)
  paymentData    Json?           @map("payment_data") // Store payment provider specific data
  paidAt         DateTime?       @map("paid_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  totalRub       Decimal         @map("total_rub") @db.Decimal(10, 2)
  totalUsd       Decimal         @map("total_usd") @db.Decimal(10, 2)
  totalAmount    Decimal?        @map("total_amount") @db.Decimal(10, 2) // For deposits and unified amount
  currency       String?         @db.VarChar(3) // Currency for the order/deposit
  quantity       Int             @default(1)
  couponCode     String?         @db.VarChar(50)
  couponDiscount Decimal         @default(0.00) @map("coupon_discount") @db.Decimal(10, 2)
  product        Product?        @relation(fields: [productId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  reservedKeys   ReservedKey[]
  purchases      UserPurchase[]

  @@index([userId])
  @@index([productId])
  @@index([variantId])
  @@index([status])
  @@index([paymentStatus])
  @@index([type])
  @@map("orders")
}

model UserPurchase {
  id             Int            @id @default(autoincrement())
  orderId        String?        @map("order_id")
  userId         Int            @map("user_id")
  productId      Int            @map("product_id")
  variantId      Int            @map("variant_id")
  price          Decimal        @db.Decimal(10, 2)
  currency       String         @db.VarChar(3)
  keys           String         @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")
  instruction    String?        @db.Text
  quantity       Int            @default(1)
  couponCode     String?        @db.VarChar(50)
  couponDiscount Decimal        @default(0.00) @map("coupon_discount") @db.Decimal(10, 2)
  order          Order?         @relation(fields: [orderId], references: [id])
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
  @@map("user_purchases")
}

model Log {
  id          Int    @id @default(autoincrement())
  user        String @db.VarChar(100)
  timestamp   BigInt
  description String @db.Text

  @@map("logs")
}

model Settings {
  id                  Int      @id @default(1)
  telegramToken       String?  @db.Text
  discordWebhook      String?  @db.Text
  stockDiscordWebhook String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model DailyRevenue {
  id         Int      @id @default(autoincrement())
  date       DateTime @unique @default(now()) @map("date")
  revenueUsd Decimal  @default(0.00) @map("revenue_usd") @db.Decimal(10, 2)
  revenueRub Decimal  @default(0.00) @map("revenue_rub") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("daily_revenue")
}

model ReservedKey {
  id          Int            @id @default(autoincrement())
  key         String         @db.VarChar(255)
  variantId   Int            @map("variant_id")
  orderId     String         @map("order_id")
  status      String         @default("reserved") @db.VarChar(20)
  reservedAt  DateTime       @default(now()) @map("reserved_at")
  usedAt      DateTime?      @map("used_at")
  cancelledAt DateTime?      @map("cancelled_at")
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([orderId])
  @@index([status])
  @@map("reserved_keys")
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  discount    Int      @default(0)
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  maxUses     Int?     @default(0)
  currentUses Int      @default(0)
  games       String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("coupons")
}

model PaymentFee {
  id            Int     @id @default(autoincrement())
  paymentMethod String  @unique @map("payment_method") @db.VarChar(50)
  percentageFee Decimal @map("percentage_fee") @db.Decimal(5, 2) @default(0.00)
  fixedFeeUsd   Decimal @map("fixed_fee_usd") @db.Decimal(10, 2) @default(0.00)
  fixedFeeRub   Decimal @map("fixed_fee_rub") @db.Decimal(10, 2) @default(0.00)
  isActive      Boolean @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("payment_fees")
}
